# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Virtual environments — use .venv (no conda)
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/
*.pyi~

# ruff
.ruff_cache/

# Data files — configs and plots go in git, raw CSVs do NOT
data/*.csv
data/*.npy
data/*.pkl
# But keep the data directory itself
!data/.gitkeep

# Large simulation results
data/shots/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE (allow Antigravity IDE files)
.idea/
*.swp
*.swo

# Environment variables / secrets
.env
*.secret

# Reports — track markdown source, not built PDFs
reports/*.pdf
reports/build/
